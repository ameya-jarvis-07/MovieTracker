<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/searchMovieFragment">

    <fragment
        android:id="@+id/searchMovieFragment"
        android:name="com.jarvis.movietracker.ui.fragment.SearchMovieFragment"
        android:label="Search Movies"
        tools:layout="@layout/fragment_search_movie">
        <action
            android:id="@+id/action_search_to_details"
            app:destination="@id/movieDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/watchlistFragment"
        android:name="com.jarvis.movietracker.ui.fragment.WatchlistFragment"
        android:label="Watchlist"
        tools:layout="@layout/fragment_watchlist">
        <action
            android:id="@+id/action_watchlist_to_details"
            app:destination="@id/movieDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/recommendationsFragment"
        android:name="com.jarvis.movietracker.ui.fragment.RecommendationsFragment"
        android:label="Recommendations"
        tools:layout="@layout/fragment_recommendations" />

    <fragment
        android:id="@+id/movieDetailsFragment"
        android:name="com.jarvis.movietracker.ui.fragment.MovieDetailsFragment"
        android:label="Movie Details"
        tools:layout="@layout/fragment_movie_details">
        <argument
            android:name="movieId"
            app:type="integer" />
        <action
            android:id="@+id/action_details_to_details"
            app:destination="@id/movieDetailsFragment" />
    </fragment>

</navigation>

